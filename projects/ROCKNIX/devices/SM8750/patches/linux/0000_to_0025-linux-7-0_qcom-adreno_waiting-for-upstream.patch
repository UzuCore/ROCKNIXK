 drivers/clk/qcom/Makefile             |   1 +
 drivers/clk/qcom/gpucc-sm8750.c       | 473 ++++++++++++++++++++++++++
 drivers/clk/qcom/gxclkctl-kaanapali.c |   1 +
 4 files changed, 484 insertions(+)
 create mode 100644 drivers/clk/qcom/gpucc-sm8750.c

