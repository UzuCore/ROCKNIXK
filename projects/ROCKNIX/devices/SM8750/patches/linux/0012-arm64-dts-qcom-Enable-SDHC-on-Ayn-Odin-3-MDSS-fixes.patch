From 91a28d8aa538293ebd31727779aac8f23cb73b39 Mon Sep 17 00:00:00 2001
From: Gianni Spadoni <me@gio.blue>
Date: Fri, 23 Jan 2026 17:25:29 +0800
Subject: [PATCH 12/20] arm64: dts: qcom: Enable SDHC on Ayn Odin 3, MDSS fixes

Enables sdhc2 / sdhc_2 on the Odin 3

Also makes some changes to MDSS on this device with the goal of fixing it up a bit

Signed-off-by: Gianni Spadoni <me@gio.blue>
---
 arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts | 61 +++++++++++++++++--
 arch/arm64/boot/dts/qcom/sm8750-mdss.dtsi     |  8 +--
 2 files changed, 61 insertions(+), 8 deletions(-)

diff --git a/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts b/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
index fa76ce3dc..96317c2c7 100644
--- a/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
+++ b/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
@@ -144,6 +144,59 @@ port@2 {
 		};
 	};
 
+	sdhc2: mmc@8804000 {
+		compatible = "qcom,sm8750-sdhci", "qcom,sdhci-msm-v5";
+		reg = <0 0x08804000 0 0x1000>;
+
+		interrupts = <GIC_SPI 207 IRQ_TYPE_LEVEL_HIGH>,
+			     <GIC_SPI 223 IRQ_TYPE_LEVEL_HIGH>;
+		interrupt-names = "hc_irq", "pwr_irq";
+
+		clocks = <&gcc GCC_SDCC2_AHB_CLK>,
+			 <&gcc GCC_SDCC2_APPS_CLK>,
+			 <&rpmhcc RPMH_CXO_CLK>;
+		clock-names = "iface", "core", "xo";
+
+		power-domains = <&rpmhpd RPMHPD_CX>;
+		operating-points-v2 = <&sdhc2_opp_table>;
+
+		interconnects = <&aggre2_noc MASTER_SDCC_2 QCOM_ICC_TAG_ALWAYS
+				 &mc_virt SLAVE_EBI1 QCOM_ICC_TAG_ALWAYS>,
+				<&gem_noc MASTER_APPSS_PROC QCOM_ICC_TAG_ACTIVE_ONLY
+				 &config_noc SLAVE_SDCC_2 QCOM_ICC_TAG_ACTIVE_ONLY>;
+		interconnect-names = "sdhc-ddr", "cpu-sdhc";
+
+		iommus = <&apps_smmu 0x540 0>;
+
+		bus-width = <4>;
+
+		dma-coherent;
+
+		sdhc2_opp_table: opp-table {
+			compatible = "operating-points-v2";
+
+			opp-19200000 {
+				opp-hz = /bits/ 64 <19200000>;
+				required-opps = <&rpmhpd_opp_min_svs>;
+			};
+
+			opp-50000000 {
+				opp-hz = /bits/ 64 <50000000>;
+				required-opps = <&rpmhpd_opp_low_svs>;
+			};
+
+			opp-100000000 {
+				opp-hz = /bits/ 64 <100000000>;
+				required-opps = <&rpmhpd_opp_svs>;
+			};
+
+			opp-202000000 {
+				opp-hz = /bits/ 64 <202000000>;
+				required-opps = <&rpmhpd_opp_svs_l1>;
+			};
+		};
+	};
+
 	vph_pwr: vph-pwr-regulator {
 		compatible = "regulator-fixed";
 
@@ -908,15 +961,15 @@ display_panel: panel@0 {
 		reg = <0>;
 		compatible = "chipone,icna3520";
 		
+		reset-gpios = <&tlmm 98 GPIO_ACTIVE_HIGH>;
+
 		vddio-supply = <&vreg_l12b_1p8>;
 		vci-supply = <&vreg_l13b_3p0>;
 		vdd-supply = <&vreg_l11b_1p0>;
-		
 		rotation = <90>;
 		
-		reset-gpios = <&tlmm 98 GPIO_ACTIVE_HIGH>;
-		pinctrl-0 = <&disp0_reset_n_active>, <&disp0_mipi_vdd_active>, <&disp0_mdp_vsync>;
-		pinctrl-1 = <&disp0_reset_n_suspend>, <&disp0_mipi_vdd_suspend>, <&disp0_mdp_vsync>;
+		pinctrl-0 = <&disp0_reset_n_active>, <&disp0_mdp_vsync>;
+		pinctrl-1 = <&disp0_reset_n_suspend>, <&disp0_mdp_vsync>;
 		pinctrl-names = "default", "sleep";
 
 		port {
diff --git a/arch/arm64/boot/dts/qcom/sm8750-mdss.dtsi b/arch/arm64/boot/dts/qcom/sm8750-mdss.dtsi
index 20c7128fa..8db273b50 100644
--- a/arch/arm64/boot/dts/qcom/sm8750-mdss.dtsi
+++ b/arch/arm64/boot/dts/qcom/sm8750-mdss.dtsi
@@ -31,8 +31,8 @@ mdss: display-subsystem@ae00000 {
 			 <&gcc GCC_DISP_HF_AXI_CLK>,
 			 <&dispcc DISP_CC_MDSS_MDP_CLK>;
 
-		// NOTE: This was originally DISP_CC_MDSS_CORE_BCR
-		resets = <&dispcc DISP_CC_MDSS_RSCC_BCR>;
+		// NOTE: Some devices have better luck with RSCC_BCR - we'll stick with CORE_BCR for now
+		resets = <&dispcc DISP_CC_MDSS_CORE_BCR>;
 
 		interconnects = <&mmss_noc MASTER_MDP QCOM_ICC_TAG_ALWAYS
 				 &mc_virt SLAVE_EBI1 QCOM_ICC_TAG_ALWAYS>,
@@ -180,7 +180,7 @@ mdss_dsi0: dsi@ae94000 {
 			#address-cells = <1>;
 			#size-cells = <0>;
 
-			status = "disabled";
+			status = "okay";
 
 			ports {
 				#address-cells = <1>;
@@ -243,7 +243,7 @@ mdss_dsi0_phy: phy@ae95000 {
 			#clock-cells = <1>;
 			#phy-cells = <0>;
 
-			status = "disabled";
+			status = "okay";
 		};
 
 		mdss_dsi1: dsi@ae96000 {
-- 
2.43.0

