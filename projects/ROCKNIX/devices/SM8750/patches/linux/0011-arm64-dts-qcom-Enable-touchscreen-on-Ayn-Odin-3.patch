From 45c2c24a3acc685ec151e5974d3b2af961318413 Mon Sep 17 00:00:00 2001
From: Gianni Spadoni <me@gio.blue>
Date: Fri, 23 Jan 2026 05:44:21 +0800
Subject: [PATCH 11/20] arm64: dts: qcom: Enable touchscreen on Ayn Odin 3

Requires the touchscreen patch (no-regmap-bulk-read) used for SM8550 devices in Rocknix

Enables the FT5426 touchscreen over I2C
---
 arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts | 51 +++++++++++++++++++
 1 file changed, 51 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts b/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
index ae48e205b..fa76ce3dc 100644
--- a/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
+++ b/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
@@ -166,6 +166,7 @@ display_pwr: display-gpio-regulator {
 		gpio = <&pm8550_gpios 11 GPIO_ACTIVE_HIGH>;
 
 		enable-active-high;
+		regulator-always-on;
 		regulator-boot-on;
 	};
 };
@@ -700,10 +701,43 @@ &uart7 {
 	status = "okay";
 };
 
+&qup_i2c4_data_clk {
+	/* Use internal I2C pull-up */
+	bias-pull-up = <2200>;
+};
+
+&i2c4 {
+	status = "okay";
+
+	clock-frequency = <400000>;
+
+	// i2c@a90000 / focaltech@38
+	display_touchscreen: touchscreen@38 {
+		status = "okay";
+		reg = <0x38>;
+		compatible = "focaltech,ft5426";
+
+		no-regmap-bulk-read;
+		
+		interrupts-extended = <&tlmm 162 IRQ_TYPE_EDGE_FALLING>;
+		reset-gpios = <&tlmm 161 GPIO_ACTIVE_LOW>;
+
+		vcc-supply = <&vreg_l14b_3p2>;
+		iovcc-supply = <&vreg_l12b_1p8>;
+
+		touchscreen-size-x = <1080>;
+		touchscreen-size-y = <1920>;
+
+		pinctrl-0 = <&ts_reset_default &ts_active_default>;
+		pinctrl-names = "default";
+	};
+};
+
 &tlmm {
 	/* reserved for secure world */
 	gpio-reserved-ranges = <36 4>, <74 1>;
 
+	// Display GPIOs
 	disp0_reset_n_active: disp0-reset-n-active-state {
 		pins = "gpio98";
 		function = "gpio";
@@ -738,6 +772,23 @@ disp0_mdp_vsync: disp0-mdp-vsync-active-state {
 		drive-strength = <2>;
 		bias-pull-down;
 	};
+
+	// Touchscreen GPIOs
+	// pmx_ts_active / ts_active
+	ts_active_default: ts-active-default-state {
+		pins = "gpio162";
+		function = "gpio";
+		drive-strength = <8>;
+		bias-pull-up;
+	};
+
+	// pmx_ts_release / ts_release
+	ts_reset_default: ts-reset-default-state {
+		pins = "gpio161";
+		function = "gpio";
+		drive-strength = <2>;
+		bias-disable;
+	};
 };
 
 /* Disabled features */
-- 
