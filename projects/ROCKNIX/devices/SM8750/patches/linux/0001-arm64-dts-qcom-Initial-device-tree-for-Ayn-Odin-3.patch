+/* Power & volume keys */
+&pm8550_gpios {
+	volume_up_n: volume-up-n-state {
+		pins = "gpio6";
+		function = "normal";
+		bias-pull-up;
+		input-enable;
+		power-source = <1>;
+	};
+};
+
+&pon_pwrkey {
+	status = "okay";
+};
+
+&pon_resin {
+	status = "okay";
+
+	linux,code = <KEY_VOLUMEDOWN>;
+};
+
+// I2C through QUPv3_1
+&gpi_dma1 {
+	status = "okay";
+};
+
+&qupv3_1 {
+	status = "okay";
+};
+
+&uart7 {
+	status = "okay";
+};
+
+&tlmm {
+	/* reserved for secure world */
+	gpio-reserved-ranges = <36 4>, <74 1>;
+};
+
+/* Disabled features */
+// Mostly regulators that don't exist on the Odin 3
+// pm8010@d is disabled
+&pm8010_n {
+	status = "disabled";
+};
+
+// pm8010@c is disabled
+&pm8010_m {
+	status = "disabled";
+};
+
+// pmr735d@a is disabled
+&pmr735d_k {
+	status = "disabled";
+};
