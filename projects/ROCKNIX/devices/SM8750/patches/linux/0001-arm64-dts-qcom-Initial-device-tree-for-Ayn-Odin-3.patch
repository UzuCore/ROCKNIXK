From c2e3cd49f97eda2629ba16e540e6780320719cc5 Mon Sep 17 00:00:00 2001
From: Gianni Spadoni <me@gio.blue>
Date: Thu, 22 Jan 2026 19:45:39 +0800
Subject: [PATCH 01/20] arm64: dts: qcom: Initial device tree for Ayn Odin 3

Basic device tree, let's add features step by step

This currently:
- boots into a shell
- has working UART serial
- has working UFS

Signed-off-by: Gianni Spadoni <me@gio.blue>
---
 arch/arm64/boot/dts/qcom/Makefile             |   1 +
 arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts | 714 ++++++++++++++++++
 2 files changed, 715 insertions(+)
 create mode 100644 arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts

diff --git a/arch/arm64/boot/dts/qcom/Makefile b/arch/arm64/boot/dts/qcom/Makefile
index 6f34d5ed3..c242a26b8 100644
--- a/arch/arm64/boot/dts/qcom/Makefile
+++ b/arch/arm64/boot/dts/qcom/Makefile
@@ -322,6 +322,7 @@ dtb-$(CONFIG_ARCH_QCOM)	+= sm8650-mtp.dtb
 dtb-$(CONFIG_ARCH_QCOM)	+= sm8650-qrd.dtb
 dtb-$(CONFIG_ARCH_QCOM)	+= sm8750-mtp.dtb
 dtb-$(CONFIG_ARCH_QCOM)	+= sm8750-qrd.dtb
+dtb-$(CONFIG_ARCH_QCOM)	+= sm8750-ayn-odin3.dtb
 x1e001de-devkit-el2-dtbs	:= x1e001de-devkit.dtb x1-el2.dtbo
 dtb-$(CONFIG_ARCH_QCOM)	+= x1e001de-devkit.dtb x1e001de-devkit-el2.dtb
 x1e78100-lenovo-thinkpad-t14s-el2-dtbs	:= x1e78100-lenovo-thinkpad-t14s.dtb x1-el2.dtbo
diff --git a/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts b/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
new file mode 100644
index 000000000..7eabe0320
--- /dev/null
+++ b/arch/arm64/boot/dts/qcom/sm8750-ayn-odin3.dts
@@ -0,0 +1,714 @@
+// SPDX-License-Identifier: BSD-3-Clause
