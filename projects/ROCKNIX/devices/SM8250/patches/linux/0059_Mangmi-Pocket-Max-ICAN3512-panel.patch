Subject: [PATCH] drm/panel: add Mangmi Pocket Max ICAN3512 panel

diff --git a/drivers/gpu/drm/panel/Kconfig b/drivers/gpu/drm/panel/Kconfig
index 307152ad7759..855198931e1d 100644
--- a/drivers/gpu/drm/panel/Kconfig
+++ b/drivers/gpu/drm/panel/Kconfig
@@ -228,6 +228,17 @@ config DRM_PANEL_HYDIS_HV101HD1
 
 	  If M is selected the module will be called panel-hydis-hv101hd1
 
+config DRM_PANEL_ICAN3512_7INCH
+	tristate "Mangmi Pocket Max ICAN3512 panel"
+	depends on OF
+	depends on DRM_MIPI_DSI
+	depends on BACKLIGHT_CLASS_DEVICE
+	select DRM_DISPLAY_DSC_HELPER
+	select DRM_DISPLAY_HELPER
+	help
+	  Say Y here to enable support for the Chipone ICNA3512 1080x1920
+	  command-mode AMOLED panel with DSC, as used on the Mangmi Pocket Max.
+
 config DRM_PANEL_ILITEK_IL9322
 	tristate "Ilitek ILI9322 320x240 QVGA panels"
 	depends on OF && SPI
diff --git a/drivers/gpu/drm/panel/Makefile b/drivers/gpu/drm/panel/Makefile
index aeffaa95666d..cd445e259b82 100644
--- a/drivers/gpu/drm/panel/Makefile
+++ b/drivers/gpu/drm/panel/Makefile
@@ -23,6 +23,7 @@ obj-$(CONFIG_DRM_PANEL_HIMAX_HX83112A) += panel-himax-hx83112a.o
 obj-$(CONFIG_DRM_PANEL_HIMAX_HX83112B) += panel-himax-hx83112b.o
 obj-$(CONFIG_DRM_PANEL_HIMAX_HX8394) += panel-himax-hx8394.o
 obj-$(CONFIG_DRM_PANEL_HYDIS_HV101HD1) += panel-hydis-hv101hd1.o
+obj-$(CONFIG_DRM_PANEL_ICAN3512_7INCH) += panel-ican3512-7inch.o
 obj-$(CONFIG_DRM_PANEL_ILITEK_IL9322) += panel-ilitek-ili9322.o
 obj-$(CONFIG_DRM_PANEL_ILITEK_ILI9341) += panel-ilitek-ili9341.o
 obj-$(CONFIG_DRM_PANEL_ILITEK_ILI9805) += panel-ilitek-ili9805.o
diff --git a/drivers/gpu/drm/panel/panel-ican3512-7inch.c b/drivers/gpu/drm/panel/panel-ican3512-7inch.c
new file mode 100644
index 000000000000..d2a003472977
--- /dev/null
+++ b/drivers/gpu/drm/panel/panel-ican3512-7inch.c
@@ -0,0 +1,476 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ *
+ * Mangmi Pocket Max panel: Chipone ICNA3512 1080x1920 command-mode AMOLED with DSC.
+ * Init sequence generated from the vendor device tree.
+ */
+
+#include <linux/backlight.h>
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/mod_devicetable.h>
+#include <linux/module.h>
+#include <linux/regulator/consumer.h>
+
+#include <video/mipi_display.h>
+
+#include <drm/display/drm_dsc.h>
+#include <drm/display/drm_dsc_helper.h>
+#include <drm/drm_atomic.h>
+#include <drm/drm_mipi_dsi.h>
+#include <drm/drm_modes.h>
+#include <drm/drm_panel.h>
+#include <drm/drm_probe_helper.h>
+
+struct ican3512_7inch {
+	struct drm_panel panel;
+	struct mipi_dsi_device *dsi;
+	struct drm_connector *connector;
+	struct drm_dsc_config dsc;
+	struct regulator_bulk_data *supplies;
+	struct gpio_desc *reset_gpio;
+	enum drm_panel_orientation orientation;
+};
+
+static const struct regulator_bulk_data ican3512_7inch_supplies[] = {
+	{ .supply = "vddio" },
+	{ .supply = "vdd" },
+	{ .supply = "enable" },
+};
+
+/*
+ * Command-mode panel: the visible refresh rate is set by the DDIC's per-rate
+ * timing block in the init sequence, not by the DSI clock. The modes keep a
+ * constant pixel clock and vary the vertical front porch so each advertises a
+ * distinct, correct vrefresh; the matching DDIC block is sent from _on().
+ */
+static const struct drm_display_mode ican3512_7inch_modes[] = {
+	{	/* 60 Hz (vendor default) */
+		.clock = (1080 + 156 + 1 + 23) * (1920 + 2760 + 1 + 15) * 60 / 1000,
+		.hdisplay = 1080,
+		.hsync_start = 1080 + 156,
+		.hsync_end = 1080 + 156 + 1,
+		.htotal = 1080 + 156 + 1 + 23,
+		.vdisplay = 1920,
+		.vsync_start = 1920 + 2760,
+		.vsync_end = 1920 + 2760 + 1,
+		.vtotal = 1920 + 2760 + 1 + 15,
+		.width_mm = 87,
+		.height_mm = 155,
+		.type = DRM_MODE_TYPE_DRIVER,
+	},
+	{	/* 90 Hz */
+		.clock = (1080 + 156 + 1 + 23) * (1920 + 1194 + 1 + 15) * 90 / 1000,
+		.hdisplay = 1080,
+		.hsync_start = 1080 + 156,
+		.hsync_end = 1080 + 156 + 1,
+		.htotal = 1080 + 156 + 1 + 23,
+		.vdisplay = 1920,
+		.vsync_start = 1920 + 1194,
+		.vsync_end = 1920 + 1194 + 1,
+		.vtotal = 1920 + 1194 + 1 + 15,
+		.width_mm = 87,
+		.height_mm = 155,
+		.type = DRM_MODE_TYPE_DRIVER,
+	},
+	{	/* 120 Hz */
+		.clock = (1080 + 156 + 1 + 23) * (1920 + 412 + 1 + 15) * 120 / 1000,
+		.hdisplay = 1080,
+		.hsync_start = 1080 + 156,
+		.hsync_end = 1080 + 156 + 1,
+		.htotal = 1080 + 156 + 1 + 23,
+		.vdisplay = 1920,
+		.vsync_start = 1920 + 412,
+		.vsync_end = 1920 + 412 + 1,
+		.vtotal = 1920 + 412 + 1 + 15,
+		.width_mm = 87,
+		.height_mm = 155,
+		.type = DRM_MODE_TYPE_DRIVER,
+	},
+	{	/* 144 Hz */
+		.clock = (1080 + 156 + 1 + 23) * (1920 + 20 + 1 + 15) * 144 / 1000,
+		.hdisplay = 1080,
+		.hsync_start = 1080 + 156,
+		.hsync_end = 1080 + 156 + 1,
+		.htotal = 1080 + 156 + 1 + 23,
+		.vdisplay = 1920,
+		.vsync_start = 1920 + 20,
+		.vsync_end = 1920 + 20 + 1,
+		.vtotal = 1920 + 20 + 1 + 15,
+		.width_mm = 87,
+		.height_mm = 155,
+		.type = DRM_MODE_TYPE_DRIVER,
+	},
+};
+
+static inline struct ican3512_7inch *to_ican3512_7inch(struct drm_panel *panel)
+{
+	return container_of_const(panel, struct ican3512_7inch, panel);
+}
+
+static int ican3512_7inch_get_current_mode(struct ican3512_7inch *ctx)
+{
+	struct drm_connector *connector = ctx->connector;
+	struct drm_crtc_state *crtc_state;
+	int i;
+
+	if (!connector || !connector->state || !connector->state->crtc)
+		return 0;
+
+	crtc_state = connector->state->crtc->state;
+
+	for (i = 0; i < ARRAY_SIZE(ican3512_7inch_modes); i++)
+		if (drm_mode_match(&crtc_state->mode, &ican3512_7inch_modes[i],
+				   DRM_MODE_MATCH_TIMINGS | DRM_MODE_MATCH_CLOCK))
+			return i;
+
+	return 0;
+}
+
+static void ican3512_7inch_reset(struct ican3512_7inch *ctx)
+{
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
+	usleep_range(20000, 21000);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+	usleep_range(20000, 21000);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
+	usleep_range(20000, 21000);
+}
+
+static int ican3512_7inch_on(struct ican3512_7inch *ctx)
+{
+	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi };
+	struct drm_dsc_picture_parameter_set pps;
+	int cur_mode = ican3512_7inch_get_current_mode(ctx);
+	int vrefresh = drm_mode_vrefresh(&ican3512_7inch_modes[cur_mode]);
+
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9c, 0xa5, 0xa5);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xfd, 0x5a, 0x5a);
+	if (vrefresh >= 90)
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x48, 0x30);
+	else
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x48, 0x00);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9f, 0x0f);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xce, 0x22);
+	mipi_dsi_dcs_exit_sleep_mode_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 255);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9f, 0x01);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xdf, 0xc5, 0x86);
+
+	switch (vrefresh) {
+	case 144:
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb3,
+			0x00, 0xe0, 0xa0, 0x10, 0xc8, 0x00, 0x02, 0x83, 0x00,
+			0x10, 0x14, 0x00, 0x00, 0xc3, 0x00, 0x10, 0x14, 0x00,
+			0x00, 0xe0, 0x00, 0x10, 0x14, 0x00, 0x00, 0xe0, 0xa0,
+			0x10, 0xc8, 0x22, 0x18, 0x18, 0x18, 0x18, 0x18);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9f, 0x07);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb5,
+			0x04, 0x0a, 0x08, 0x0a, 0x04, 0x00, 0xc4);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xd9,
+			0x66, 0xe4, 0xe4, 0x66, 0xe4, 0xe4, 0x00, 0xc4, 0x00,
+			0x00, 0x00, 0x00, 0x00, 0x00, 0x00);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xce,
+			0x01, 0x01, 0x01, 0x01, 0x04, 0x07, 0xa4);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x48, 0x30);
+		break;
+	case 120:
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb3,
+			0x00, 0xe0, 0xa0, 0x10, 0xc8, 0x00, 0x02, 0x83, 0x00,
+			0x10, 0x14, 0x00, 0x00, 0xc3, 0x00, 0x10, 0x14, 0x00,
+			0x00, 0xe0, 0x10, 0x10, 0x9c, 0x00, 0x00, 0xe0, 0xa0,
+			0x10, 0xc8, 0x22, 0x18, 0x18, 0x18, 0x18, 0x18);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9f, 0x07);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb5,
+			0x04, 0x0c, 0x08, 0x0c, 0x04, 0x00, 0xc4);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xd9,
+			0x88, 0x40, 0x40, 0x88, 0x40, 0x40, 0x00, 0xeb, 0x00,
+			0x00, 0x00, 0x00, 0x00, 0x00, 0x00);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xce,
+			0x01, 0x01, 0x01, 0x01, 0x04, 0x09, 0x2c);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x48, 0x30);
+		break;
+	case 90:
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb3,
+			0x00, 0xe0, 0x40, 0x10, 0xa8, 0x00);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9f, 0x07);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb2,
+			0x04, 0x10, 0x08, 0x0c, 0x04, 0x00, 0xc4);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xd3,
+			0x55, 0x80, 0x80, 0x55, 0x80, 0x80, 0x00, 0x9c, 0x00,
+			0x00, 0x00, 0x00, 0x00, 0x00, 0x00);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xcb,
+			0x01, 0x01, 0x01, 0x01, 0x04, 0x06, 0x1c);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x48, 0x00);
+		break;
+	default: /* 60 Hz */
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb3,
+			0x00, 0xe0, 0xa0, 0x10, 0xc8, 0x00);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9f, 0x07);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb2,
+			0x04, 0x18, 0x08, 0x0c, 0x04, 0x00, 0xc4);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xd3,
+			0x88, 0x4a, 0x4a, 0x88, 0x4a, 0x4a, 0x00, 0xeb, 0x00,
+			0x00, 0x00, 0x00, 0x00, 0x00, 0x00);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xcb,
+			0x01, 0x01, 0x01, 0x01, 0x04, 0x09, 0x2c);
+		mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x48, 0x00);
+		break;
+	}
+
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x9f, 0x02);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xbe,
+		0x04, 0x00, 0x10, 0x10, 0x00, 0x03, 0x02, 0x07, 0xa4,
+		0x01, 0x00, 0x00, 0x40, 0x20, 0x00, 0x00);
+	mipi_dsi_dcs_set_display_brightness_multi(&dsi_ctx, 0x0000);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, MIPI_DCS_WRITE_CONTROL_DISPLAY,
+				     0xe0);
+	mipi_dsi_dcs_set_tear_on_multi(&dsi_ctx, MIPI_DSI_DCS_TEAR_MODE_VBLANK);
+
+	drm_dsc_pps_payload_pack(&pps, &ctx->dsc);
+	mipi_dsi_picture_parameter_set_multi(&dsi_ctx, &pps);
+
+	mipi_dsi_dcs_set_display_on_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 50);
+
+	return dsi_ctx.accum_err;
+}
+
+static int ican3512_7inch_prepare(struct drm_panel *panel)
+{
+	struct ican3512_7inch *ctx = to_ican3512_7inch(panel);
+	struct device *dev = &ctx->dsi->dev;
+	int ret;
+
+	ret = regulator_bulk_enable(ARRAY_SIZE(ican3512_7inch_supplies), ctx->supplies);
+	if (ret < 0) {
+		dev_err(dev, "Failed to enable regulators: %d\n", ret);
+		return ret;
+	}
+
+	ican3512_7inch_reset(ctx);
+
+	ret = ican3512_7inch_on(ctx);
+	if (ret < 0) {
+		dev_err(dev, "Failed to initialize panel: %d\n", ret);
+		gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+		regulator_bulk_disable(ARRAY_SIZE(ican3512_7inch_supplies), ctx->supplies);
+		return ret;
+	}
+
+	return 0;
+}
+
+static int ican3512_7inch_unprepare(struct drm_panel *panel)
+{
+	struct ican3512_7inch *ctx = to_ican3512_7inch(panel);
+
+	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+	regulator_bulk_disable(ARRAY_SIZE(ican3512_7inch_supplies), ctx->supplies);
+
+	return 0;
+}
+
+static int ican3512_7inch_get_modes(struct drm_panel *panel,
+				    struct drm_connector *connector)
+{
+	struct ican3512_7inch *ctx = to_ican3512_7inch(panel);
+	int i, count = 0;
+
+	ctx->connector = connector;
+
+	for (i = 0; i < ARRAY_SIZE(ican3512_7inch_modes); i++) {
+		struct drm_display_mode *mode;
+
+		mode = drm_mode_duplicate(connector->dev, &ican3512_7inch_modes[i]);
+		if (!mode)
+			return -ENOMEM;
+
+		drm_mode_set_name(mode);
+		mode->type |= (i == 0) ? DRM_MODE_TYPE_PREFERRED : 0;
+		drm_mode_probed_add(connector, mode);
+		count++;
+	}
+
+	connector->display_info.width_mm = ican3512_7inch_modes[0].width_mm;
+	connector->display_info.height_mm = ican3512_7inch_modes[0].height_mm;
+	return count;
+}
+
+static enum drm_panel_orientation ican3512_7inch_get_orientation(struct drm_panel *panel)
+{
+	struct ican3512_7inch *ctx = to_ican3512_7inch(panel);
+
+	return ctx->orientation;
+}
+
+static int ican3512_7inch_disable(struct drm_panel *panel)
+{
+	struct ican3512_7inch *ctx = to_ican3512_7inch(panel);
+	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi };
+
+	mipi_dsi_dcs_set_display_off_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 50);
+	mipi_dsi_dcs_enter_sleep_mode_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 120);
+
+	return dsi_ctx.accum_err;
+}
+
+static const struct drm_panel_funcs ican3512_7inch_panel_funcs = {
+	.prepare = ican3512_7inch_prepare,
+	.disable = ican3512_7inch_disable,
+	.unprepare = ican3512_7inch_unprepare,
+	.get_modes = ican3512_7inch_get_modes,
+	.get_orientation = ican3512_7inch_get_orientation,
+};
+
+static int ican3512_7inch_bl_update_status(struct backlight_device *bl)
+{
+	struct mipi_dsi_device *dsi = bl_get_data(bl);
+	u16 brightness = backlight_get_brightness(bl);
+	int ret;
+
+	dsi->mode_flags &= ~MIPI_DSI_MODE_LPM;
+
+	ret = mipi_dsi_dcs_set_display_brightness_large(dsi, brightness);
+	if (ret < 0)
+		return ret;
+
+	dsi->mode_flags |= MIPI_DSI_MODE_LPM;
+
+	return 0;
+}
+
+static int ican3512_7inch_bl_get_brightness(struct backlight_device *bl)
+{
+	struct mipi_dsi_device *dsi = bl_get_data(bl);
+	u16 brightness;
+	int ret;
+
+	dsi->mode_flags &= ~MIPI_DSI_MODE_LPM;
+
+	ret = mipi_dsi_dcs_get_display_brightness_large(dsi, &brightness);
+	if (ret < 0)
+		return ret;
+
+	dsi->mode_flags |= MIPI_DSI_MODE_LPM;
+
+	return brightness;
+}
+
+static const struct backlight_ops ican3512_7inch_bl_ops = {
+	.update_status = ican3512_7inch_bl_update_status,
+	.get_brightness = ican3512_7inch_bl_get_brightness,
+};
+
+static struct backlight_device *
+ican3512_7inch_create_backlight(struct mipi_dsi_device *dsi)
+{
+	struct device *dev = &dsi->dev;
+	const struct backlight_properties props = {
+		.type = BACKLIGHT_RAW,
+		.brightness = 3515,
+		.max_brightness = 3515,
+	};
+
+	return devm_backlight_device_register(dev, dev_name(dev), dev, dsi,
+					      &ican3512_7inch_bl_ops, &props);
+}
+
+static int ican3512_7inch_probe(struct mipi_dsi_device *dsi)
+{
+	struct device *dev = &dsi->dev;
+	struct ican3512_7inch *ctx;
+	int ret;
+
+	ctx = devm_drm_panel_alloc(dev, struct ican3512_7inch, panel,
+				   &ican3512_7inch_panel_funcs,
+				   DRM_MODE_CONNECTOR_DSI);
+	if (IS_ERR(ctx))
+		return PTR_ERR(ctx);
+
+	ret = devm_regulator_bulk_get_const(dev,
+					    ARRAY_SIZE(ican3512_7inch_supplies),
+					    ican3512_7inch_supplies,
+					    &ctx->supplies);
+	if (ret < 0)
+		return ret;
+
+	ctx->reset_gpio = devm_gpiod_get(dev, "reset", GPIOD_OUT_HIGH);
+	if (IS_ERR(ctx->reset_gpio))
+		return dev_err_probe(dev, PTR_ERR(ctx->reset_gpio),
+				     "Failed to get reset-gpios\n");
+
+	ret = of_drm_get_panel_orientation(dev->of_node, &ctx->orientation);
+	if (ret < 0)
+		return dev_err_probe(dev, ret, "Failed to get orientation\n");
+
+	ctx->dsi = dsi;
+	mipi_dsi_set_drvdata(dsi, ctx);
+
+	dsi->lanes = 4;
+	dsi->format = MIPI_DSI_FMT_RGB888;
+	dsi->mode_flags = MIPI_DSI_CLOCK_NON_CONTINUOUS | MIPI_DSI_MODE_LPM;
+
+	ctx->panel.prepare_prev_first = true;
+
+	ctx->panel.backlight = ican3512_7inch_create_backlight(dsi);
+	if (IS_ERR(ctx->panel.backlight))
+		return dev_err_probe(dev, PTR_ERR(ctx->panel.backlight),
+				     "Failed to create backlight\n");
+
+	drm_panel_add(&ctx->panel);
+
+	dsi->dsc = &ctx->dsc;
+
+	ctx->dsc.dsc_version_major = 1;
+	ctx->dsc.dsc_version_minor = 1;
+
+	ctx->dsc.slice_height = 20;
+	ctx->dsc.slice_width = 540;
+	WARN_ON(1080 % ctx->dsc.slice_width);
+	ctx->dsc.slice_count = 1080 / ctx->dsc.slice_width;
+	ctx->dsc.bits_per_component = 8;
+	ctx->dsc.bits_per_pixel = 8 << 4;
+	ctx->dsc.block_pred_enable = true;
+
+	ret = mipi_dsi_attach(dsi);
+	if (ret < 0) {
+		drm_panel_remove(&ctx->panel);
+		return dev_err_probe(dev, ret, "Failed to attach to DSI host\n");
+	}
+
+	return 0;
+}
+
+static void ican3512_7inch_remove(struct mipi_dsi_device *dsi)
+{
