# SM6115-specific minimal system-sleep handler.

dpms() {
  if [ -z "${SWAYSOCK}" ]; then
    SWAYSOCK="$(find /run/user/*/sway-ipc.*.sock 2>/dev/null | head -1)"
    [ -n "${SWAYSOCK}" ] && export SWAYSOCK
  fi
  swaymsg "output * power ${1}" 2>/dev/null
}

BT_UART_WAKEUP=/sys/devices/platform/soc@0/4ac0000.geniqup/4a8c000.serial/power/wakeup

bt_uart_wakeup() {
  [ -e "${BT_UART_WAKEUP}" ] && echo "${1}" > "${BT_UART_WAKEUP}"
}

case $1 in
  pre)
    dpms off
    bt_uart_wakeup disabled
    ;;
  post)
    bt_uart_wakeup enabled
    dpms on
    ;;
esac

exit 0
