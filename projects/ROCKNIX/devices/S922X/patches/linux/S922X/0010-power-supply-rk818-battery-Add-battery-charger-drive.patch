+/* =========================================================================
+ * Charger / battery supply
+ * ========================================================================= */
+
+static int rk818_charger_set_current_max(struct rk818_battery *di, int val)
+{
+	unsigned reg;
+	int ret;
+
+	if (val < 1000000)
+		reg = 0;
+	else if (val < 3000000)
+		reg = (val - 1000000) / 200000;
+	else
+		reg = 10;
+
+	ret = regmap_update_bits(di->regmap, RK818_CHRG_CTRL_REG1,
+				 RK818_CHRG_CTRL_REG1_CHRG_CUR_SEL_MASK,
+				 reg << RK818_CHRG_CTRL_REG1_CHRG_CUR_SEL_OFFSET);
+	if (ret)
+		dev_err(di->dev,
+			"Charging max current setting failed (%d)\n", ret);
+
+	return ret;
+}
+
+static int rk818_charger_get_current_max(struct rk818_battery *di, int *val)
+{
+	unsigned reg;
+	int ret;
+
+	ret = regmap_read(di->regmap, RK818_CHRG_CTRL_REG1, &reg);
+	if (ret) {
+		dev_err(di->dev,
+			"Charging max current getting failed (%d)\n", ret);
+		return ret;
+	}
+
+	reg &= RK818_CHRG_CTRL_REG1_CHRG_CUR_SEL_MASK;
+	reg >>= RK818_CHRG_CTRL_REG1_CHRG_CUR_SEL_OFFSET;
+
+	*val = 1000000 + reg * 200000;
+
+	return 0;
+}
+
+static int rk818_charger_set_voltage_max(struct rk818_battery *di, int val)
+{
+	unsigned reg;
+	int ret;
+
+	if (val < 4050000)
+		reg = 0;
+	else if (val < 4350000)
+		reg = (val - 4050000) / 50000;
+	else
+		reg = 6;
+
+	ret = regmap_update_bits(di->regmap, RK818_CHRG_CTRL_REG1,
+				 RK818_CHRG_CTRL_REG1_CHRG_VOL_SEL_MASK,
+				 reg << RK818_CHRG_CTRL_REG1_CHRG_VOL_SEL_OFFSET);
+	if (ret)
+		dev_err(di->dev,
+			"Charging end voltage setting failed (%d)\n", ret);
+
+	return ret;
+}
+
+static int rk818_charger_get_voltage_max(struct rk818_battery *di, int *val)
+{
+	unsigned reg;
+	int ret;
+
+	ret = regmap_read(di->regmap, RK818_CHRG_CTRL_REG1, &reg);
+	if (ret) {
+		dev_err(di->dev,
+			"Charging end voltage getting failed (%d)\n", ret);
+		return ret;
+	}
+
+	reg &= RK818_CHRG_CTRL_REG1_CHRG_VOL_SEL_MASK;
+	reg >>= RK818_CHRG_CTRL_REG1_CHRG_VOL_SEL_OFFSET;
+
+	*val = 4050000 + reg * 50000;
+
+	return 0;
+}
+
+static int rk818_charger_get_property(struct power_supply *psy,
+				      enum power_supply_property psp,
+				      union power_supply_propval *val)
+{
+	struct rk818_battery *di = power_supply_get_drvdata(psy);
+	unsigned reg;
+	int ret;
+
+	/* Properties delegated to the fuel-gauge */
+	switch (psp) {
+	case POWER_SUPPLY_PROP_CURRENT_NOW:
+	case POWER_SUPPLY_PROP_VOLTAGE_NOW:
+	case POWER_SUPPLY_PROP_VOLTAGE_OCV:
+	case POWER_SUPPLY_PROP_PRESENT:
+	case POWER_SUPPLY_PROP_CAPACITY:
+	case POWER_SUPPLY_PROP_TEMP:
+	case POWER_SUPPLY_PROP_STATUS:
+	case POWER_SUPPLY_PROP_CHARGE_FULL:
+		return rk818_bat_get_property(di, psp, val);
+	default:
+		break;
+	}
+
+	switch (psp) {
+	case POWER_SUPPLY_PROP_ONLINE:
+		ret = regmap_read(di->regmap, RK818_CHRG_CTRL_REG1, &reg);
+		if (ret) {
+			dev_err(di->dev, "failed to read the charger state (%d)\n", ret);
+			return ret;
+		}
+
+		val->intval = !!(reg & RK818_CHRG_CTRL_REG1_CHRG_EN);
+		break;
+
+	case POWER_SUPPLY_PROP_CHARGE_BEHAVIOUR:
+		ret = regmap_read(di->regmap, RK818_CHRG_CTRL_REG1, &reg);
+		if (ret) {
+			dev_err(di->dev, "failed to read the charger state (%d)\n", ret);
+			return ret;
+		}
+
+		if (reg & RK818_CHRG_CTRL_REG1_CHRG_EN)
+			val->intval = POWER_SUPPLY_CHARGE_BEHAVIOUR_AUTO;
+		else
+			val->intval = POWER_SUPPLY_CHARGE_BEHAVIOUR_INHIBIT_CHARGE;
+
+		return 0;
+
+	case POWER_SUPPLY_PROP_CHARGE_TYPE:
+		ret = regmap_read(di->regmap, RK818_SUP_STS_REG, &reg);
+		if (ret)
+			return ret;
+
+		switch (reg & RK818_CHG_STS_MASK) {
+		case RK818_CHG_STS_WAKEUP_CUR:
+		case RK818_CHG_STS_TRICKLE_CUR:
+			val->intval = POWER_SUPPLY_CHARGE_TYPE_TRICKLE;
+			break;
+		case RK818_CHG_STS_CC_OR_CV:
+			val->intval = POWER_SUPPLY_CHARGE_TYPE_FAST;
+			break;
+		case RK818_CHG_STS_TERMINATED:
+			val->intval = POWER_SUPPLY_CHARGE_TYPE_NONE;
+			break;
+		default:
+			val->intval = POWER_SUPPLY_CHARGE_TYPE_UNKNOWN;
+			break;
+		}
+
+		break;
+
+	case POWER_SUPPLY_PROP_CHARGE_TERM_CURRENT:
+		ret = regmap_read(di->regmap, RK818_CHRG_CTRL_REG2, &reg);
+		if (ret)
+			return ret;
+
+		val->intval = 100000 + ((reg >> 6) & 3) * 50000;
+		break;
+
+	case POWER_SUPPLY_PROP_HEALTH:
+		ret = regmap_read(di->regmap, RK818_SUP_STS_REG, &reg);
+		if (ret)
+			return ret;
+
+		switch (reg & RK818_CHG_STS_MASK) {
+		case RK818_CHG_STS_USB_OV:
+			val->intval = POWER_SUPPLY_HEALTH_OVERVOLTAGE;
+			break;
+		case RK818_CHG_STS_BAT_TEMP_FAULT:
+			val->intval = POWER_SUPPLY_HEALTH_OVERHEAT;
+			break;
+		case RK818_CHG_STS_TIMEOUT:
+			val->intval = POWER_SUPPLY_HEALTH_SAFETY_TIMER_EXPIRE;
+			break;
+		default:
+			val->intval = POWER_SUPPLY_HEALTH_GOOD;
+			break;
+		}
+
+		break;
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE:
+		return rk818_charger_get_voltage_max(di, &val->intval);
+
+	case POWER_SUPPLY_PROP_PRECHARGE_CURRENT:
+		ret = rk818_charger_get_current_max(di, &val->intval);
+		val->intval /= 10;
+		return ret;
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT:
+		return rk818_charger_get_current_max(di, &val->intval);
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE_MAX:
+		val->intval = di->info->constant_charge_voltage_max_uv;
+		break;
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT_MAX:
+		val->intval = di->info->constant_charge_current_max_ua;
+		break;
+
+	case POWER_SUPPLY_PROP_ENERGY_FULL_DESIGN:
+		val->intval = di->info->energy_full_design_uwh;
+		return 0;
+
+	case POWER_SUPPLY_PROP_ENERGY_EMPTY_DESIGN:
+		val->intval = 0;
+		return 0;
+
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int rk818_charger_set_property(struct power_supply *psy,
+				      enum power_supply_property psp,
+				      const union power_supply_propval *val)
+{
+	struct rk818_battery *di = power_supply_get_drvdata(psy);
+
+	switch (psp) {
+	case POWER_SUPPLY_PROP_CHARGE_BEHAVIOUR:
+		switch (val->intval) {
+		case POWER_SUPPLY_CHARGE_BEHAVIOUR_AUTO:
+			return regmap_update_bits(di->regmap, RK818_CHRG_CTRL_REG1,
+						  RK818_CHRG_CTRL_REG1_CHRG_EN,
+						  RK818_CHRG_CTRL_REG1_CHRG_EN);
+		case POWER_SUPPLY_CHARGE_BEHAVIOUR_INHIBIT_CHARGE:
+			return regmap_update_bits(di->regmap, RK818_CHRG_CTRL_REG1,
+						  RK818_CHRG_CTRL_REG1_CHRG_EN, 0);
+		default:
+			return -EINVAL;
+		}
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE:
+		return rk818_charger_set_voltage_max(di, val->intval);
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT:
+		return rk818_charger_set_current_max(di, val->intval);
+
+	default:
+		return -EINVAL;
+	}
+}
+
+static int rk818_charger_prop_writeable(struct power_supply *psy,
+					enum power_supply_property psp)
+{
+	switch (psp) {
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT:
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE:
+	case POWER_SUPPLY_PROP_CHARGE_BEHAVIOUR:
+		return 1;
+
+	default:
+		return 0;
+	}
+}
+
+static enum power_supply_property rk818_charger_props[] = {
+	POWER_SUPPLY_PROP_ONLINE,
+	POWER_SUPPLY_PROP_HEALTH,
+	POWER_SUPPLY_PROP_STATUS,
+	POWER_SUPPLY_PROP_CHARGE_BEHAVIOUR,
+	POWER_SUPPLY_PROP_CHARGE_TYPE,
+	POWER_SUPPLY_PROP_CHARGE_TERM_CURRENT,
+	POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT,
+	POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE,
+	POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT_MAX,
+	POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE_MAX,
+	POWER_SUPPLY_PROP_PRECHARGE_CURRENT,
+	POWER_SUPPLY_PROP_ENERGY_FULL_DESIGN,
+	POWER_SUPPLY_PROP_ENERGY_EMPTY_DESIGN,
+	POWER_SUPPLY_PROP_CHARGE_FULL_DESIGN,
+	POWER_SUPPLY_PROP_VOLTAGE_MIN_DESIGN,
+	POWER_SUPPLY_PROP_VOLTAGE_MAX_DESIGN,
+	POWER_SUPPLY_PROP_TECHNOLOGY,
+
+	/* Fuel-gauge properties exposed on the battery supply */
+	POWER_SUPPLY_PROP_CURRENT_NOW,
+	POWER_SUPPLY_PROP_VOLTAGE_NOW,
+	POWER_SUPPLY_PROP_VOLTAGE_OCV,
+	POWER_SUPPLY_PROP_PRESENT,
+	POWER_SUPPLY_PROP_CAPACITY,
+	POWER_SUPPLY_PROP_TEMP,
+	POWER_SUPPLY_PROP_CHARGE_FULL,
+};
+
+static const struct power_supply_desc rk818_charger_desc = {
+	.name			= "rk818-battery",
+	.type			= POWER_SUPPLY_TYPE_BATTERY,
+	.properties		= rk818_charger_props,
+	.num_properties		= ARRAY_SIZE(rk818_charger_props),
+	.property_is_writeable	= rk818_charger_prop_writeable,
+	.get_property		= rk818_charger_get_property,
+	.set_property		= rk818_charger_set_property,
+	.charge_behaviours	= BIT(POWER_SUPPLY_CHARGE_BEHAVIOUR_AUTO) |
+				  BIT(POWER_SUPPLY_CHARGE_BEHAVIOUR_INHIBIT_CHARGE),
+};
+
+static int rk818_parse_dt(struct rk818_battery *di)
+{
+	struct device *dev = di->dev;
+	struct device_node *np = dev->of_node;
+	u32 val;
+	int length;
+	int ret;
+
+	/* Defaults for optional properties */
+	di->monitor_sec		   = 5;
+	di->relax_entry_current_ma = 300;
+	di->relax_exit_current_ma  = 300;
+	di->max_soc_offset_pct	   = 60;
+	di->sense_resist_mohm	   = 20;
+	di->feedback_temp	   = 105;	/* Celsius */
+	di->cccv_timeout_h	   = 12;	/* hours */
+
+	if (!of_property_read_u32(np, "rockchip,sense-resistor-micro-ohms",
+				  &val))
+		di->sense_resist_mohm = val / 1000;
+
+	of_property_read_u32(np, "rockchip,monitor-sec", &di->monitor_sec);
+
+	if (!of_property_read_u32(np, "rockchip,relax-entry-current-microamp",
+				  &val))
+		di->relax_entry_current_ma = val / 1000;
+	if (!of_property_read_u32(np, "rockchip,relax-exit-current-microamp",
+				  &val))
+		di->relax_exit_current_ma = val / 1000;
+
+	of_property_read_u32(np, "rockchip,max-soc-offset-percent",
+			     &di->max_soc_offset_pct);
+
+	/*
+	 * HOTDIE threshold, in Celsius.  The register only supports
+	 * 85/95/105/115 C; the nearest lower entry is selected at
+	 * register-write time.  A DT value of 0 disables the feature.
+	 */
+	of_property_read_u32(np, "rockchip,feedback-temp-celsius",
+			     &di->feedback_temp);
+
+	/*
+	 * CC/CV safety timer, in hours.  The register only supports
+	 * 4/5/6/8/10/12/14/16 h; the nearest lower entry is selected at
+	 * register-write time.  A DT value of 0 disables the timer.
+	 */
+	of_property_read_u32(np, "rockchip,cccv-timeout-hours",
+			     &di->cccv_timeout_h);
+
+	/*
+	 * NTC battery thermistor table.
+	 *
+	 * "rockchip,ntc-table" is a flat array of <degree_celsius resistance_ohms>
+	 * pairs.  Degrees are signed (negative temperatures allowed), resistances
+	 * are ohms.  Entries must be sorted by temperature ascending, which for
+	 * an NTC means resistance is strictly descending.  The table may be
+	 * sparse (any step, not necessarily 1 C) -- lookup interpolates.
+	 *
+	 * Example:
+	 *   rockchip,ntc-table = <
+	 *       (-20) 26458836
+	 *       (-15) 20048010
+	 *       ( -6) 12489321
+	 *       ...
+	 *   >;
+	 */
+	if (of_find_property(np, "rockchip,ntc-table", &length)) {
+		unsigned int cells = length / sizeof(u32);
+		unsigned int i;
+		size_t size;
+
+		if (cells < 4 || (cells & 1)) {
+			dev_err(di->dev,
+				"rockchip,ntc-table must be an array of >=2 <deg res> pairs\n");
+			return -EINVAL;
+		}
+
+		di->ntc_size = cells / 2;
+		size = sizeof(*di->ntc_entries) * di->ntc_size;
+		di->ntc_entries = devm_kzalloc(di->dev, size, GFP_KERNEL);
+		if (!di->ntc_entries)
+			return -ENOMEM;
+
+		for (i = 0; i < di->ntc_size; i++) {
+			struct rk818_ntc_entry *e = &di->ntc_entries[i];
+			u32 temp_cell;
+
+			/*
+			 * of_property_read_s32_index does not exist -- read as
+			 * u32 and reinterpret.  DT cells are 32-bit two's
+			 * complement, so a negative value like -20 arrives as
+			 * 0xffffffec and the (s32) cast recovers -20.
+			 */
+			ret = of_property_read_u32_index(np, "rockchip,ntc-table",
+							 2 * i, &temp_cell);
+			if (ret)
+				return ret;
+			e->temp = (s32)temp_cell;
+
+			ret = of_property_read_u32_index(np, "rockchip,ntc-table",
+							 2 * i + 1, &e->res);
+			if (ret)
+				return ret;
+
+			if (i > 0) {
+				const struct rk818_ntc_entry *p = &di->ntc_entries[i - 1];
+
+				if (e->temp <= p->temp) {
+					dev_err(di->dev,
+						"rockchip,ntc-table: temps must be strictly ascending (entry %u: %d <= %d)\n",
+						i, e->temp, p->temp);
+					return -EINVAL;
+				}
+				if (e->res >= p->res) {
+					dev_err(di->dev,
+						"rockchip,ntc-table: resistances must be strictly descending (entry %u: %u >= %u)\n",
+						i, e->res, p->res);
+					return -EINVAL;
+				}
+			}
+		}
+	}
+
+	return 0;
+}
+
+/* -------------------------------------------------------------------------
+ * Probe / shutdown
+ * ------------------------------------------------------------------------- */
+
+static int rk818_battery_probe(struct platform_device *pdev)
+{
+	struct rk808 *rk818 = dev_get_drvdata(pdev->dev.parent);
+	struct power_supply_config psy_cfg = { };
+	struct device *dev = &pdev->dev;
+	struct rk818_battery *di;
+	int ret, vb_lo_irq;
+
+	di = devm_kzalloc(dev, sizeof(*di), GFP_KERNEL);
+	if (!di)
+		return -ENOMEM;
+
+	di->rk818 = rk818;
+	di->pdev = pdev;
+	di->dev = dev;
+	di->regmap = rk818->regmap;
+	platform_set_drvdata(pdev, di);
+
+	ret = rk818_parse_dt(di);
+	if (ret)
+		return ret;
+
+	if (!rk818_battery_present(di))
+		return dev_err_probe(di->dev, -ENODEV,
+				     "no battery detected\n");
+
+	di->res_div = (di->sense_resist_mohm == 20) ? 1 : 2;
+	di->monitor_ms = di->monitor_sec * 1000;
+	if (!di->monitor_ms)
+		di->monitor_ms = MONITOR_MS_DEFAULT;
+
+	/*
+	 * Plausible placeholder (20.0 C) until the first monitor cycle
+	 * runs rk818_update_temperature().  Without this, userspace could
+	 * briefly observe 0.0 C between power-supply registration and the
+	 * first poll.
+	 */
+	di->temperature = 200;
+
+	di->boot_base_jiffies = jiffies;
+
+	/*
+	 * Register power supplies first: the power-supply core will
+	 * parse the "monitored-battery" phandle on our fwnode and
+	 * populate psy->battery_info with the standard simple-battery
+	 * properties.  The gauge init sequence below depends on those
+	 * values (design capacity, OCV table, internal resistance,
+	 * shutdown voltage), so it must run afterwards.
+	 */
+	psy_cfg.drv_data = di;
+	psy_cfg.fwnode = dev_fwnode(dev);
+
+	di->usb_psy = devm_power_supply_register(dev, &rk818_usb_desc,
+						 &psy_cfg);
+	if (IS_ERR(di->usb_psy))
+		return dev_err_probe(dev, PTR_ERR(di->usb_psy),
+				     "register usb power supply fail\n");
+
+	di->charger_psy = devm_power_supply_register(dev, &rk818_charger_desc,
+						     &psy_cfg);
+	if (IS_ERR(di->charger_psy))
+		return dev_err_probe(dev, PTR_ERR(di->charger_psy),
+				     "register charger power supply fail\n");
+
+	di->info = di->charger_psy->battery_info;
+	if (!di->info)
+		return dev_err_probe(dev, -ENODEV,
+				     "monitored-battery info not available\n");
+
+	rk818_enable_gauge(di);
+	rk818_init_voltage_kb(di);
+	rk818_init_coffset(di);
+	rk818_configure_sampling(di);
+	rk818_configure_relax_thresholds(di);
+	rk818_init_soc(di);
+	rk818_configure_charger(di);
+	rk818_init_ts1_detect(di);
+	rk818_set_low_voltage_irq(di);
+
+	/* disable voltage limit and enable input current limit */
+	ret = regmap_update_bits(di->regmap, RK818_SUP_STS_REG,
+				 RK818_SUP_STS_USB_ILIM_EN | RK818_SUP_STS_USB_VLIM_EN,
+				 RK818_SUP_STS_USB_ILIM_EN);
+	if (ret)
+		dev_warn(di->dev, "failed to enable input current limit (%d)\n", ret);
+
+	/* make sure analog control loop is enabled */
+	ret = regmap_update_bits(di->regmap, RK818_CHRG_CTRL_REG3,
+				 RK818_CHRG_CTRL_REG3_CHRG_TERM_DIGITAL,
+				 0);
+	if (ret)
+		dev_warn(di->dev, "failed to enable analog control loop (%d)\n", ret);
+
+	/* enable charger and set some reasonable limits on each boot */
+	ret = regmap_write(di->regmap, RK818_CHRG_CTRL_REG1,
+			   RK818_CHRG_CTRL_REG1_CHRG_EN
+			   | (1) /* 1.2A */
+			   | (5 << 4) /* 4.3V */);
+	if (ret)
+		dev_warn(di->dev, "failed to enable charger (%d)\n", ret);
+
+	rk818_usb_power_external_power_changed(di->usb_psy);
+
+	vb_lo_irq = regmap_irq_get_virq(rk818->irq_data, RK818_IRQ_VB_LO);
+	if (vb_lo_irq < 0)
+		return dev_err_probe(di->dev, vb_lo_irq,
+				     "cannot get vb_lo virq\n");
+
+	ret = devm_request_threaded_irq(di->dev, vb_lo_irq, NULL,
+					rk818_vb_low_irq,
+					IRQF_TRIGGER_HIGH | IRQF_ONESHOT,
+					"rk818_vb_low", di);
+	if (ret)
+		return dev_err_probe(di->dev, ret,
+				     "failed to request vb_lo IRQ\n");
+
+	enable_irq_wake(vb_lo_irq);
+
+	di->wq = alloc_ordered_workqueue("rk818-bat",
+					 WQ_MEM_RECLAIM | WQ_FREEZABLE);
+	if (!di->wq)
+		return -ENOMEM;
+
+	INIT_DELAYED_WORK(&di->work, rk818_battery_work);
+	queue_delayed_work(di->wq, &di->work, msecs_to_jiffies(di->monitor_ms));
+
+	dev_info(di->dev, "ready: dsoc=%d%% fcc=%d mAh sense=%u mOhm\n",
+		 di->dsoc, di->fcc_mah, di->sense_resist_mohm);
+	return 0;
+}
+
+static void rk818_battery_shutdown(struct platform_device *pdev)
+{
+	struct rk818_battery *di = platform_get_drvdata(pdev);
+
+	cancel_delayed_work_sync(&di->work);
+
+	rk818_save_dsoc(di);
+	rk818_save_remain_cap(di);
+
+	dev_info(di->dev,
+		 "shutdown: dsoc=%d rsoc=%d i=%d mA v=%d mV cap=%d mAh\n",
+		 di->dsoc, di->rsoc, di->current_avg_ma,
+		 di->voltage_avg_mv, di->remain_cap_mah);
+}
+
+static const struct of_device_id rk818_battery_of_match[] = {
+	{ .compatible = "rockchip,rk818-charger" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, rk818_battery_of_match);
+
+static struct platform_driver rk818_battery_driver = {
+	.probe    = rk818_battery_probe,
+	.suspend  = rk818_battery_suspend,
+	.resume   = rk818_battery_resume,
+	.shutdown = rk818_battery_shutdown,
+	.driver   = {
+		.name           = "rk818-charger",
+		.of_match_table = rk818_battery_of_match,
+	},
+};
+module_platform_driver(rk818_battery_driver);
+
+MODULE_LICENSE("GPL");
+MODULE_ALIAS("platform:rk818-charger");
+MODULE_AUTHOR("Ondrej Jirman <megi@xff.cz>");
+MODULE_DESCRIPTION("RK818 battery and charger driver");
