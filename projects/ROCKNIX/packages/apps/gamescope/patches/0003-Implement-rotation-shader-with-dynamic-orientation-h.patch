From 985287a7faad7e5d600ac0c2ce26f18a97297738 Mon Sep 17 00:00:00 2001
From: tiopex <tiopxyz@gmail.com>
Date: Sun, 26 Apr 2026 21:48:26 +0200
Subject: [PATCH] Implement rotation shader with dynamic orientation handling

---
 src/Backends/DRMBackend.cpp  |  7 ++-----
 src/main.hpp                 |  3 +++
 src/rendervulkan.cpp         | 12 ++++++++++++
 src/shaders/blit_push_data.h |  3 +++
 src/shaders/cs_rotation.comp | 15 +++++++++++++--
 src/wlserver.cpp             | 15 +++++++++++++--
 6 files changed, 46 insertions(+), 9 deletions(-)

diff --git a/src/Backends/DRMBackend.cpp b/src/Backends/DRMBackend.cpp
index dfe0293..8d652f0 100644
--- a/src/Backends/DRMBackend.cpp
+++ b/src/Backends/DRMBackend.cpp
@@ -2207,11 +2207,8 @@ namespace gamescope
 	{
 		if ( this->GetScreenType() == GAMESCOPE_SCREEN_TYPE_INTERNAL && l_bEnableRotationShader )
 		{
-			drm_log.infof( "Using rotation shader" );
-			if ( g_DesiredInternalOrientation == GAMESCOPE_PANEL_ORIENTATION_270 )
-				m_ChosenOrientation = GAMESCOPE_PANEL_ORIENTATION_180;
-			else
-				m_ChosenOrientation = GAMESCOPE_PANEL_ORIENTATION_0;
+			drm_log.infof( "Using rotation shader, desired orientation: %d", (int)g_DesiredInternalOrientation );
+			m_ChosenOrientation = GAMESCOPE_PANEL_ORIENTATION_0;
 			return;
 		}
 
diff --git a/src/main.hpp b/src/main.hpp
index e33cb27..1280fca 100644
--- a/src/main.hpp
+++ b/src/main.hpp
@@ -4,6 +4,8 @@
 
 #include <atomic>
 
+#include "gamescope_shared.h"
+
 extern const char *gamescope_optstring;
 extern const struct option *gamescope_options;
 
@@ -22,6 +24,7 @@ extern int g_nOutputRefresh; // mHz
 extern bool g_bOutputHDREnabled;
 extern bool g_bForceInternal;
 extern bool g_bUseRotationShader;
+extern GamescopePanelOrientation g_DesiredInternalOrientation;
 
 extern bool g_bFullscreen;
 
diff --git a/src/rendervulkan.cpp b/src/rendervulkan.cpp
index 34b3650..8f2dc5e 100644
--- a/src/rendervulkan.cpp
+++ b/src/rendervulkan.cpp
@@ -3695,6 +3695,8 @@ struct BlitPushData_t
     float u_itmSdrNits; // unset
     float u_itmTargetNits; // unset
 
+    uint32_t u_rotationType; // 0 = 90° CCW, 1 = 90° CW, 2 = 180°
+
 	explicit BlitPushData_t(const struct FrameInfo_t *frameInfo)
 	{
 		u_shaderFilter = 0;
@@ -3735,6 +3737,15 @@ struct BlitPushData_t
 		u_nitsToLinear = 1.0f / g_flInternalDisplayBrightnessNits;
 		u_itmSdrNits = g_flHDRItmSdrNits;
 		u_itmTargetNits = g_flHDRItmTargetNits;
+
+		// Determine rotation type from desired orientation
+		// 0 = 90° CCW (panel orientation 90/left), 1 = 90° CW (panel orientation 270/right), 2 = 180°
+		if (g_DesiredInternalOrientation == GAMESCOPE_PANEL_ORIENTATION_270)
+			u_rotationType = 1;
+		else if (g_DesiredInternalOrientation == GAMESCOPE_PANEL_ORIENTATION_180)
+			u_rotationType = 2;
+		else
+			u_rotationType = 0; // default: 90° CCW
 	}
 
 	explicit BlitPushData_t(float blit_scale) {
@@ -3756,6 +3767,7 @@ struct BlitPushData_t
 		u_nitsToLinear = 1.0f / g_flInternalDisplayBrightnessNits;
 		u_itmSdrNits = g_flHDRItmSdrNits;
 		u_itmTargetNits = g_flHDRItmTargetNits;
+		u_rotationType = 0;
 	}
 };
 
diff --git a/src/shaders/blit_push_data.h b/src/shaders/blit_push_data.h
index caff0f3..0a7129b 100644
--- a/src/shaders/blit_push_data.h
+++ b/src/shaders/blit_push_data.h
@@ -16,5 +16,8 @@ uniform layers_t {
     float u_nitsToLinear; // hdr -> sdr
     float u_itmSdrNits;
     float u_itmTargetNits;
+
+    // Rotation shader: 0 = 90° CCW (left), 1 = 90° CW (right), 2 = 180°
+    uint u_rotationType;
 };
 
diff --git a/src/shaders/cs_rotation.comp b/src/shaders/cs_rotation.comp
index 1a47fd5..061a00f 100644
--- a/src/shaders/cs_rotation.comp
+++ b/src/shaders/cs_rotation.comp
@@ -46,8 +46,19 @@ void main() {
 
     outputValue.rgb = encodeOutputColor(outputValue.rgb);
 
-    // Rotate the pixel coordinates counter-clockwise by 90 degrees
-    ivec2 rotatedCoord = ivec2(coord.y, outWidth - coord.x - 1);
+    // Rotate based on u_rotationType:
+    // 0 = 90° CCW (left), 1 = 90° CW (right), 2 = 180°
+    ivec2 rotatedCoord;
+    if (u_rotationType == 1u) {
+        // 90° CW (right): (x,y) -> (height-1-y, x)
+        rotatedCoord = ivec2(outHeight - coord.y - 1, coord.x);
+    } else if (u_rotationType == 2u) {
+        // 180°: (x,y) -> (width-1-x, height-1-y)
+        rotatedCoord = ivec2(outHeight - coord.x - 1, outWidth - coord.y - 1);
+    } else {
+        // 90° CCW (left): (x,y) -> (y, width-1-x)
+        rotatedCoord = ivec2(coord.y, outWidth - coord.x - 1);
+    }
 
     imageStore(dst, rotatedCoord, outputValue);
 }
diff --git a/src/wlserver.cpp b/src/wlserver.cpp
index d0c52ce..92ab2d8 100644
--- a/src/wlserver.cpp
+++ b/src/wlserver.cpp
@@ -2831,8 +2831,19 @@ static void apply_touchscreen_orientation(GamescopePanelOrientation orientation,
 			break;
 	}
 	if (g_bUseRotationShader) {
-		tx = 1.0 - *y;
-		ty = *x;
+		if (g_DesiredInternalOrientation == GAMESCOPE_PANEL_ORIENTATION_270) {
+			// 90° CW
+			tx = *y;
+			ty = 1.0 - *x;
+		} else if (g_DesiredInternalOrientation == GAMESCOPE_PANEL_ORIENTATION_180) {
+			// 180°
+			tx = 1.0 - *x;
+			ty = 1.0 - *y;
+		} else {
+			// 90° CCW (default)
+			tx = 1.0 - *y;
+			ty = *x;
+		}
 	}
 	*x = tx;
 	*y = ty;
-- 
2.43.0

