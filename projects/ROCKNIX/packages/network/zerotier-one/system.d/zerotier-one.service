[Unit]
Description=zerotier-one
Wants=network-online.target
After=network-online.target

[Service]
ExecStart=/usr/sbin/zerotier-one /storage/.config/zerotier/
ExecStartPost=/usr/sbin/zerotier-join.sh
Restart=always
KillMode=process
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
