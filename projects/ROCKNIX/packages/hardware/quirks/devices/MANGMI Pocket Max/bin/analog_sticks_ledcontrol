# Pocket Max aw20036 rings are exposed per-channel

LED="/sys/class/leds"
MAX=$(cat ${LED}/red:indicator-0/max_brightness 2>/dev/null || echo 255)

if [ $# -ne 7 ]; then
  echo "Usage: $0 <brightness> <right_red> <right_green> <right_blue> <left_red> <left_green> <left_blue>"
  echo "Example: $0 255 255 0 0 0 0 255"
  exit 1
fi

BRIGHTNESS=$1
RIGHT_RED=$2; RIGHT_GREEN=$3; RIGHT_BLUE=$4
LEFT_RED=$5; LEFT_GREEN=$6; LEFT_BLUE=$7

chan() { echo $(( $1 * BRIGHTNESS * MAX / 65025 )); }

set_pixel() {
  echo $(chan $2) > ${LED}/red:indicator-$1/brightness
  echo $(chan $3) > ${LED}/green:indicator-$1/brightness
  echo $(chan $4) > ${LED}/blue:indicator-$1/brightness
}

# left ring = 0-7, right ring = 8-15
for i in 0 1 2 3 4 5 6 7; do
  set_pixel $i $LEFT_RED $LEFT_GREEN $LEFT_BLUE
done
for i in 8 9 10 11 12 13 14 15; do
  set_pixel $i $RIGHT_RED $RIGHT_GREEN $RIGHT_BLUE
done
