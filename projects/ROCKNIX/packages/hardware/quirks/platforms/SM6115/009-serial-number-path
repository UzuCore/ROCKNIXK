# Device serial  = Qualcomm SoC serial
# Product serial = Mangmi serial

PRODUCT_SN=$(dd if=/dev/disk/by-partlabel/tsnv bs=512 skip=944 count=1 2>/dev/null \
  | tr -c 'A-Za-z0-9' '\n' | grep -m1 -E '^MQ6[0-9][0-9A-Za-z]{8,}$')

cat <<EOF >/storage/.config/profile.d/009-serial-number-path
DEVICE_SERIAL_NUMBER_PATH=("/sys/devices/soc0/serial_number")
DEVICE_PRODUCT_SERIAL="${PRODUCT_SN}"
EOF
