# Enable USB runtime autosuspend on SM6115.

DWC3_CORE=/sys/devices/platform/soc@0/4ef8800.usb/4e00000.usb/power/control
[ -w "${DWC3_CORE}" ] && echo auto > "${DWC3_CORE}"

DWC3_WRAPPER=/sys/devices/platform/soc@0/4ef8800.usb/power/control
[ -w "${DWC3_WRAPPER}" ] && echo auto > "${DWC3_WRAPPER}"

exit 0
