THOR_WIREPLUMBER_CONF="/storage/.config/wireplumber/wireplumber.conf.d/90-thor-lite.conf"

if [ "${QUIRK_DEVICE}" == "AYN Thor Lite" ]; then
  if [ ! -f "${THOR_WIREPLUMBER_CONF}" ]; then
    mkdir -p /storage/.config/wireplumber/wireplumber.conf.d
    cat << EOF > "${THOR_WIREPLUMBER_CONF}"
monitor.alsa.rules = [
    {
        matches = [
            { node.name = "~alsa_output.*HiFi__Speaker.*" }
        ]
        actions = {
            update-props = {
            audio.format = "S16LE"
            audio.rate   = 48000
            audio.channels = 2
            }
        }
    }
]
EOF
    systemctl restart wireplumber
  fi
else
  if [ -f "${THOR_WIREPLUMBER_CONF}" ]; then
    rm -f "${THOR_WIREPLUMBER_CONF}"
    systemctl restart wireplumber
  fi
fi
