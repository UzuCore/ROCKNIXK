DEVICE_TEMP_SENSOR=""
for zone in /sys/devices/virtual/thermal/thermal_zone*/; do
  type=$(cat "${zone}type" 2>/dev/null)
  case "${type}" in
    pm8550-thermal|pm8550b-thermal|pm8550ve-thermal|battery)
      continue
      ;;
  esac
  DEVICE_TEMP_SENSOR="${DEVICE_TEMP_SENSOR} ${zone}temp"
done

echo "DEVICE_TEMP_SENSOR=\"${DEVICE_TEMP_SENSOR}\"" >/storage/.config/profile.d/005-thermal_path
