. /etc/profile.d/001-functions

### Prefer suspend-to-RAM (mem). When enabled, rocknix-fake-suspend exits
### immediately and systemd-logind handles KEY_POWER (see input_sense).

MYSLEEPMODE=$(get_setting system.suspendmode)
### Previous quirk forced "off"; migrate that default to real suspend.
if [ -z "${MYSLEEPMODE}" ] || [ "${MYSLEEPMODE}" = "off" ]
then
  /usr/bin/suspendmode mem
fi

cat <<EOF >~/.config/logind.conf.d/login.conf
[Login]
HandlePowerKey=suspend
HandleSuspendKey=suspend
EOF

systemctl try-restart systemd-logind.service 2>/dev/null || true
