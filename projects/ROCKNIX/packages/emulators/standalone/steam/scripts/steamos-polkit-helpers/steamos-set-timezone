set -e

. /etc/profile

TZ="${1:?timezone required}"
ZONEINFO="/usr/share/zoneinfo/${TZ}"

[ -e "${ZONEINFO}" ] || {
  echo "steamos-set-timezone: unknown timezone '${TZ}'" >&2
  exit 1
}

set_setting system.timezone "${TZ}"
echo -n "TIMEZONE=${TZ}" > /storage/.cache/timezone
echo -n "${TZ}" > /storage/.cache/system_timezone
systemctl restart tz-data.service
timedatectl set-timezone "${TZ}"
