diff --git a/vita3k/kernel/src/kernel.cpp b/vita3k/kernel/src/kernel.cpp
index d36f8c37..dffd3175 100644
--- a/vita3k/kernel/src/kernel.cpp
+++ b/vita3k/kernel/src/kernel.cpp
@@ -199,24 +199,31 @@ void KernelState::process_exit() {
 }
 
 void KernelState::pause_threads() {
+    threads_paused.store(true, std::memory_order_relaxed);
     const std::lock_guard<std::mutex> lock(mutex);
     for (auto &[_, thread] : threads) {
         paused_threads_status[thread->id] = thread->status;
-        if (thread->status == ThreadStatus::run)
+        if (thread->status == ThreadStatus::run) {
+            thread->suspended_by_pause = true;
             thread->suspend();
+        }
     }
 }
 
 void KernelState::resume_threads() {
+    threads_paused.store(false, std::memory_order_relaxed);
     const std::lock_guard<std::mutex> lock(mutex);
     for (auto &[_, thread] : threads) {
-        if (paused_threads_status[thread->id] == ThreadStatus::run)
+        if (thread->suspended_by_pause) {
+            thread->suspended_by_pause = false;
             thread->resume();
+        }
     }
     paused_threads_status.clear();
 }
 
 void KernelState::deinit(MemState &mem) {
+    threads_paused.store(false, std::memory_order_relaxed);
     process_exit();
     threads.clear();
 
