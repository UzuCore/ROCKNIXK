   image = ply_image_resize(image, buffer->area.width, buffer->area.height);
 
-  animate_at_time (buffer, image);
+  // Check command line argument first, then fall back to panel rotation
+  if (argc >= 3) {
+    rotation_angle = atof(argv[2]) * M_PI / 180.0;
+  } else {
+    panel_rotation = get_panel_rotation();
+    if (panel_rotation != 0) {
+      rotation_angle = panel_rotation * M_PI / 180.0;
+    }
+  }
+
+  // Only rotate if we have a non-zero rotation
+  if (rotation_angle != 0.0) {
+    center_x = ply_image_get_width(image) / 2;
+    center_y = ply_image_get_height(image) / 2;
+    rotated_image = ply_image_rotate(image, center_x, center_y, rotation_angle);
+    animate_at_time(buffer, rotated_image);
+    ply_image_free(rotated_image);
+  } else {
+    animate_at_time(buffer, image);
+  }
 
   ply_frame_buffer_close (buffer);
   ply_frame_buffer_free (buffer);
