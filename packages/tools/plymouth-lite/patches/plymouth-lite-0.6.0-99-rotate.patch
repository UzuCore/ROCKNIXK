 #include <linux/fb.h>
 #include "ply-frame-buffer.h"
 
@@ -50,6 +55,7 @@
 
 #define CLAMP(a,b,c) (MIN (MAX ((a), (b)), (c)))
 
+static char rotation_path[PATH_MAX] = {0};
 
 typedef union
 {
@@ -430,6 +436,50 @@ animate_at_time (ply_frame_buffer_t *buffer,
 
 }
 
+static int find_rotation_file(const char *fpath, const struct stat *sb, int typeflag) {
+  if (typeflag == FTW_F && strstr(fpath, "rotation") != NULL) {
+    // Try to read the file to verify it's the right one
+    FILE *fp = fopen(fpath, "rb");
+    if (fp) {
+      uint32_t test_val;
+      if (fread(&test_val, sizeof(uint32_t), 1, fp) == 1) {
+        test_val = be32toh(test_val);
+        // Assume it's our rotation file if value is reasonable
+        if (test_val == 0 || test_val == 90 || test_val == 180 || test_val == 270) {
+          strncpy(rotation_path, fpath, PATH_MAX - 1);
+          fclose(fp);
+          return 1; // Stop searching
+        }
+      }
+      fclose(fp);
+    }
+  }
+  return 0;
+}
+
+static int get_panel_rotation(void) {
+  uint32_t rotation = 0;
+  FILE *fp;
+
+  // Start search from device tree root
+  if (ftw("/proc/device-tree", find_rotation_file, 20) == -1) {
+    return 0;
+  }
+
+  // If we found a path, read the rotation value
+  if (rotation_path[0] != '\0') {
+    fp = fopen(rotation_path, "rb");
+    if (fp) {
+      if (fread(&rotation, sizeof(uint32_t), 1, fp) == 1) {
+        rotation = be32toh(rotation);
+      }
+      fclose(fp);
+    }
+  }
+
+  return (int)rotation;
+}
+
 int
 main (int    argc,
       char **argv)
@@ -437,6 +487,10 @@ main (int    argc,
   ply_image_t *image;
